{
  "name": "@nqlib/nqchart",
  "version": "0.1.3",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "dev": "next dev",
    "build": "pnpm sync:skills && pnpm run registry:fresh && next build",
    "sync:skills": "pnpm exec tsx scripts/sync-consumer-skills.mts",
    "skill:validate": "node scripts/validate-skills.mjs",
    "start": "next start",
    "lint": "eslint",
    "clean": "rm -rf node_modules && rm -rf .next && rm -rf .source",
    "registry:build": "pnpm exec tsx ./src/scripts/build-registry.mts",
    "registry:clean": "rm -rf public/r && rm -rf registry.json && rm -rf src/registry/__index__.tsx",
    "registry:fresh": "pnpm run registry:clean && pnpm run registry:build",
    "audit:previews": "node src/scripts/audit-doc-previews.mjs",
    "audit:registry-boundary": "node src/scripts/audit-registry-boundary.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "capture:readme": "pnpm exec tsx scripts/capture-readme-screenshots.mts",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:types": "node scripts/build-types.mjs",
    "build:npm": "rm -rf dist && pnpm run build:lib && pnpm run build:types",
    "verify:publish": "node scripts/verify-publish.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "prepack": "node scripts/strip-deps-for-publish.mjs prepack",
    "postpack": "node scripts/strip-deps-for-publish.mjs postpack",
    "prepublishOnly": "pnpm run verify:publish"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    },
    "patchedDependencies": {
      "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@carbon/icons-react": "^11.71.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^3.1.0",
    "@hugeicons/react": "^1.1.4",
    "@mantine/hooks": "^8.3.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/transformers": "^4.2.0",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^5.6.0",
    "embla-carousel-react": "^8.6.0",
    "front-matter": "^4.0.2",
    "fumadocs-core": "^16.3.2",
    "fumadocs-mdx": "^14.2.2",
    "fumadocs-ui": "^16.3.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.26",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.69.0",
    "rehype-pretty-code": "^0.14.1",
    "rimraf": "^6.1.2",
    "shadcn": "^3.6.2",
    "shiki": "^3.20.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ts-morph": "^26.0.0",
    "tsx": "^4.21.0",
    "vaul": "^1.1.2",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "playwright": "^1.52.0",
    "prettier": "^3.7.4",
    "prettier-plugin-sort-imports": "^1.8.9",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^8.1.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/lib/public.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/lib/public.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./recipes": {
      "types": "./dist/types/registry/lib/chart-recipes.d.ts",
      "import": "./dist/recipes.mjs",
      "require": "./dist/recipes.cjs"
    },
    "./area-chart": {
      "types": "./dist/types/registry/charts/area-chart.d.ts",
      "import": "./dist/area-chart.mjs",
      "require": "./dist/area-chart.cjs"
    },
    "./bar-chart": {
      "types": "./dist/types/registry/charts/bar-chart.d.ts",
      "import": "./dist/bar-chart.mjs",
      "require": "./dist/bar-chart.cjs"
    },
    "./calendar-chart": {
      "types": "./dist/types/registry/charts/calendar-chart.d.ts",
      "import": "./dist/calendar-chart.mjs",
      "require": "./dist/calendar-chart.cjs"
    },
    "./composed-chart": {
      "types": "./dist/types/registry/charts/composed-chart.d.ts",
      "import": "./dist/composed-chart.mjs",
      "require": "./dist/composed-chart.cjs"
    },
    "./funnel-chart": {
      "types": "./dist/types/registry/charts/funnel-chart.d.ts",
      "import": "./dist/funnel-chart.mjs",
      "require": "./dist/funnel-chart.cjs"
    },
    "./heatmap-chart": {
      "types": "./dist/types/registry/charts/heatmap-chart.d.ts",
      "import": "./dist/heatmap-chart.mjs",
      "require": "./dist/heatmap-chart.cjs"
    },
    "./line-chart": {
      "types": "./dist/types/registry/charts/line-chart.d.ts",
      "import": "./dist/line-chart.mjs",
      "require": "./dist/line-chart.cjs"
    },
    "./pie-chart": {
      "types": "./dist/types/registry/charts/pie-chart.d.ts",
      "import": "./dist/pie-chart.mjs",
      "require": "./dist/pie-chart.cjs"
    },
    "./radar-chart": {
      "types": "./dist/types/registry/charts/radar-chart.d.ts",
      "import": "./dist/radar-chart.mjs",
      "require": "./dist/radar-chart.cjs"
    },
    "./radial-chart": {
      "types": "./dist/types/registry/charts/radial-chart.d.ts",
      "import": "./dist/radial-chart.mjs",
      "require": "./dist/radial-chart.cjs"
    },
    "./scatter-chart": {
      "types": "./dist/types/registry/charts/scatter-chart.d.ts",
      "import": "./dist/scatter-chart.mjs",
      "require": "./dist/scatter-chart.cjs"
    },
    "./sparkline-chart": {
      "types": "./dist/types/registry/charts/sparkline-chart.d.ts",
      "import": "./dist/sparkline-chart.mjs",
      "require": "./dist/sparkline-chart.cjs"
    },
    "./treemap-chart": {
      "types": "./dist/types/registry/charts/treemap-chart.d.ts",
      "import": "./dist/treemap-chart.mjs",
      "require": "./dist/treemap-chart.cjs"
    },
    "./waterfall-chart": {
      "types": "./dist/types/registry/charts/waterfall-chart.d.ts",
      "import": "./dist/waterfall-chart.mjs",
      "require": "./dist/waterfall-chart.cjs"
    }
  },
  "files": [
    "dist",
    "skills/consumer/nqchart",
    "README.md"
  ],
  "peerDependencies": {
    "echarts": "^5.6.0",
    "motion": "^12.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
